{
    "begin_year": 0,
    "end_year": 6,

    "dropout": 0.0,
    "lr": 0.01,
    "batch_size": 64,
    "epoch": 100,

    "gpuid": 1,

    "loss": "mse",
    "activation": "relu",
    "scheduler": "none",

    "y_len": 12,

    "data_process": 0,

    "raw_data_path": "data/PEMS04/RawData/",
    "save_data_path": "data/PEMS04/FastData/",
    "graph_path": "data/PEMS04/graph/",
    "model_path": "log/PEMS04/",

    "method": "STID",
    "logname": "stid",

    "init": true,
    "train": 1,
    "auto_test": 0,

    "strategy": "incremental",
    "increase": true,
    "num_hops": 2,

    "detect": false,
    "ewc": false,
    "replay": false,

    "gcn": {
        "in_channel": 12,
        "hidden_channel": 32,
        "out_channel": 32
    },

    "tcn": {
        "in_channel": 1,
        "out_channel": 1,
        "kernel_size": 3,
        "dilation": 1
    },

    "stid": {
        "node_dim": 32,
        "embed_dim": 32,
        "num_layer": 3,
        "temp_dim_tid": 0,
        "temp_dim_diw": 0,
        "if_node": true,
        "if_T_i_D": false,
        "if_D_i_W": false,
        "time_of_day_size": 288,
        "day_of_week_size": 7
    }
}