{
    "begin_year": 0,
    "end_year": 6,

    "dropout": 0.1,
    "lr": 0.0001,
    "batch_size": 64,
    "epoch": 100,

    "gpuid": 1,

    "loss": "mse",
    "activation": "gelu",
    "scheduler": "none",

    "y_len": 12,

    "data_process": 0,

    "raw_data_path": "data/PEMS04/RawData/",
    "save_data_path": "data/PEMS04/FastData/",
    "graph_path": "data/PEMS04/graph/",
    "model_path": "log/PEMS04/",

    "method": "itransformer",
    "logname": "itransformer_baseline",

    "init": true,
    "train": 1,
    "auto_test": 0,

    "strategy": "incremental",
    "increase": true,
    "num_hops": 2,

    "detect": false,
    "ewc": false,
    "replay": false,

    "gcn": {
        "in_channel": 12,
        "hidden_channel": 32,
        "out_channel": 32
    },

    "itransformer": {
        "output_attention": false,
        "use_norm": true,
        "d_model": 128,
        "embed": "timeF",
        "freq": "h",
        "dropout": 0.1,
        "factor": 3,
        "n_heads": 8,
        "d_ff": 256,
        "e_layers": 3,
        "activation": "gelu"
    }
}