{
    "begin_year": 2011,
    "end_year": 2017,

    "dropout": 0.0,
    "lr": 0.03,
    "batch_size": 64,
    "epoch": 50,

    "gpuid": 1,

    "loss": "mse",
    "activation": "relu",
    "scheduler": "none",

    "y_len": 12,

    "data_process": 0,

    "raw_data_path": "data/PEMS03/RawData/",
    "save_data_path": "data/PEMS03/FastData/",
    "graph_path": "data/PEMS03/graph/",
    "model_path": "log/PEMS03/",

    "method": "gwnet",
    "logname": "gwnet",

    "init": true,
    "train": 1,
    "auto_test": 0,

    "strategy": "incremental",
    "increase": true,
    "num_hops": 2,

    "detect": false,
    "ewc": false,
    "replay": false,

    "gcn": {
        "in_channel": 12,
        "hidden_channel": 32,
        "out_channel": 32
    },

    "tcn": {
        "in_channel": 1,
        "out_channel": 1,
        "kernel_size": 3,
        "dilation": 1
    },

    "gwnet": {
        "residual_channels": 32,
        "dilation_channels": 32,
        "skip_channels": 256,
        "end_channels": 512,
        "kernel_size": 2,
        "blocks": 4,
        "layers": 2,
        "gcn_bool": true,
        "addaptadj": true
    }
}